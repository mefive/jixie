# Production env for the jixie API (loaded by systemd via EnvironmentFile).
# Copy to .env.production ON THE SERVER and fill real values. Never commit the real file.

# SQLite lives OUTSIDE the code dir so redeploys never touch it. This DB holds the whole market
# history — rebuilding it means a full Tushare backfill (hours-to-a-day, rate-limited). systemd grants
# write only to this dir (ReadWritePaths). See docs/deployment.md for seeding it.
DATABASE_URL="file:/var/lib/jixie/prod.db"

# Port the Hono server listens on (nginx reverse-proxies /api/ here).
PORT=3001

# Production mode: secure (HTTPS-only) cookies + NO dev console fallback for OTP.
# NOTE: secure cookies require the site be served over HTTPS, or the login session won't stick.
NODE_ENV=production

# Tushare token — REQUIRED. The app refuses to boot without it (config.ts throws), and it's what the
# daily market sync uses. Get it from https://tushare.pro (your account's token).
TUSHARE_TOKEN=""

# Email one-time login codes (Resend). In production the code is NOT logged to console, so a working
# key + a verified sender domain are required for anyone to log in.
RESEND_API_KEY=""
EMAIL_FROM=""

# DeepSeek (NL -> strategy/factor code, the Agent). Needed for the codegen / Agent features; the rest
# of the app works without it. BASE_URL / MODEL have sane defaults.
DEEPSEEK_API_KEY=""
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# DEEPSEEK_MODEL="deepseek-chat"

# Tushare request throttle (ms between calls). Raise if you hit rate limits on a low-points account.
# TUSHARE_MIN_INTERVAL_MS=400
