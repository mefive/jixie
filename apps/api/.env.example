# Prisma：相对路径相对 schema.prisma 解析，file:./dev.db 实际落在 apps/api/prisma/dev.db
DATABASE_URL="file:./dev.db"

# 默认 3001（避开 marginalia / fangtu 默认占用的 3000）
PORT=3001

# Tushare token —— 注册 https://tushare.pro 后在「个人主页 → 接口 TOKEN」复制
TUSHARE_TOKEN=

# 可选：覆盖 Tushare API 地址（默认 http://api.tushare.pro）
# TUSHARE_BASE_URL=http://api.tushare.pro

# 邮件验证码（Resend）。https://resend.com/api-keys 申请 key 并配置发件域名。
# 本地未配置（任一字段为空）且非生产时，验证码打印到后端控制台而非真发邮件。
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"
