# Prisma：相对路径相对 schema.prisma 解析，file:./dev.db 实际落在 apps/api/prisma/dev.db
DATABASE_URL="file:./dev.db"

# 默认 3001（避开 marginalia / fangtu 默认占用的 3000）
PORT=3001

# Tushare token —— 注册 https://tushare.pro 后在「个人主页 → 接口 TOKEN」复制
TUSHARE_TOKEN=

# 可选：覆盖 Tushare API 地址（默认 http://api.tushare.pro）
# TUSHARE_BASE_URL=http://api.tushare.pro

# 可选：两次请求最小间隔 ms（默认 400≈150次/分钟；账户低频额度 200/分钟）。
# 拉财务（80次/分钟）时需调大到 ≥750。
# TUSHARE_MIN_INTERVAL_MS=400

# 邮件验证码（Resend）。https://resend.com/api-keys 申请 key 并配置发件域名。
# 本地未配置（任一字段为空）且非生产时，验证码打印到后端控制台而非真发邮件。
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"

# NL→IR（自然语言转策略）。DeepSeek（openai 兼容端点），https://platform.deepseek.com 申请 key。
# 未配置时 /api/app/strategy/parse 返回 SERVICE_UNAVAILABLE；不影响配置式回测。
DEEPSEEK_API_KEY=""
# 可选：覆盖模型 / 端点（默认 deepseek-chat / https://api.deepseek.com）
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
