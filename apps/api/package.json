{
  "name": "api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "backup": "node scripts/backup-db.mjs",
    "gen:stats-doc": "tsx scripts/gen-stats-doc.ts",
    "gen:invite": "tsx --env-file=.env scripts/gen-invite.ts",
    "factor:report": "tsx --env-file=.env scripts/factor-report.ts",
    "backtest": "tsx --env-file=.env scripts/backtest.ts",
    "code:backtest": "tsx --env-file=.env scripts/code-backtest.ts",
    "turtle": "tsx --env-file=.env scripts/turtle.ts",
    "zeng:timing": "tsx --env-file=.env scripts/zeng-timing.ts",
    "zeng:backtest": "tsx --env-file=.env scripts/zeng-backtest.ts",
    "smoke": "tsx --env-file=.env scripts/smoke.ts",
    "sync": "tsx --env-file=.env scripts/sync.ts",
    "sync:basic": "tsx --env-file=.env scripts/sync-basic.ts",
    "sync:fina": "tsx --env-file=.env scripts/sync-fina.ts",
    "sync:index": "tsx --env-file=.env scripts/sync-index.ts",
    "sync:limit": "tsx --env-file=.env scripts/sync-limit.ts",
    "sync:moneyflow": "tsx --env-file=.env scripts/sync-moneyflow.ts",
    "sync:toplist": "tsx --env-file=.env scripts/sync-toplist.ts",
    "peek": "tsx --env-file=.env scripts/peek.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@hono/zod-validator": "^0.8.0",
    "@jixie/shared": "workspace:*",
    "@prisma/client": "^6.16.0",
    "dayjs": "^1.11.13",
    "esbuild": "^0.28.1",
    "hono": "^4.9.0",
    "isolated-vm": "^7.0.0",
    "openai": "^6.44.0",
    "ulid": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "prisma": "^6.16.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
