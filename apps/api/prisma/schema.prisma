generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Market base data. Field names use camelCase (Prisma convention), converted from Tushare's
// snake_case on ingest. Primary key is "code + trade date", which together with
// "delete the day first, then createMany" makes repeatable syncs idempotent.
// ============================================================================

/// Stock list (full overwrite refresh)
model StockBasic {
  tsCode     String  @id
  symbol     String
  name       String
  area       String?
  industry   String?
  market     String
  listDate   String
  listStatus String
}

/// Trading calendar
model TradeCal {
  exchange     String
  calDate      String
  isOpen       Int
  pretradeDate String?

  @@id([exchange, calDate])
}

/// Daily bars (unadjusted). Backtests derive backward-adjusted (hfq) prices via close × adjFactor.
model Daily {
  tsCode    String
  tradeDate String
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  preClose  Float?
  pctChg    Float?
  vol       Float?
  amount    Float?

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
}

/// Adjustment factor
model AdjFactor {
  tsCode    String
  tradeDate String
  adjFactor Float

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
}

// ============================================================================
// User system (invite-only beta). Passwordless: log in with email + 6-digit verification code;
// registering a new email requires a one-time invite code.
// Sessions use an opaque DB session id stored in the sid cookie (not JWT); logout deletes the row
// for instant invalidation. Design borrowed from marginalia / fangtu apps/api. IDs are
// application-generated ULIDs.
// ============================================================================

/// User
model User {
  id        String   @id // ULID
  email     String   @unique // unique identity; normalized with trim+lowercase before read/write
  name      String?
  status    String   @default("active") // 'active' | 'disabled' (disabling does not delete the account)
  createdAt DateTime @default(now())

  sessions Session[]
}

/// Login session. id = session token (stored in sid cookie). 30-day TTL; expiry enforced by filtering on expiresAt at query time.
model Session {
  id        String   @id // ULID, i.e. the token in the cookie
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt]) // reserved for a future cleanup job
}

/// Invite code (one-time). 12-char Crockford Base32, batch-generated by the gen-invite script.
model InviteCode {
  code        String    @id // the invite code itself is the primary key
  status      String    @default("unused") // 'unused' | 'used' | 'revoked'
  usedByEmail String? // email that consumed it
  usedAt      DateTime?
  note        String? // admin note
  createdAt   DateTime  @default(now())

  @@index([status])
}

// ============================================================================
// Factor-value pre-compute table (modeled on fangtu's derived wide tables). Each row = factor ×
// stock × rebalance date. Factor values are computed and stored across the whole market (no
// pre-filter); universe filtering is done point-in-time during the backtest.
// ============================================================================
model FactorValue {
  factor    String // factor key: 'mom' | 'rev' | 'vol'
  tsCode    String
  tradeDate String // rebalance date (month-end trading day)
  value     Float

  @@id([factor, tsCode, tradeDate])
  @@index([factor, tradeDate]) // backtest reads a full cross-section by factor+date
}

/// Email verification challenge. Only the SHA256 of the code is stored, 10-min TTL, rejected at attempts≥5 (anti-brute-force).
model EmailLoginChallenge {
  id         String    @id // ULID = challengeId
  email      String
  inviteCode String? // only set on the registration path
  codeHash   String // SHA256(6-digit verification code)
  expiresAt  DateTime
  consumedAt DateTime? // marked after successful verification, to prevent replay
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email, expiresAt])
}
