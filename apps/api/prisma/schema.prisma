generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Market base data. Field names use camelCase (Prisma convention), converted from Tushare's
// snake_case on ingest. Primary key is "code + trade date", which together with
// "delete the day first, then createMany" makes repeatable syncs idempotent.
// ============================================================================

/// Stock list (full overwrite refresh)
model StockBasic {
  tsCode     String  @id
  symbol     String
  name       String
  area       String?
  industry   String?
  market     String
  listDate   String
  listStatus String
}

/// Shenwan (SW2021) level-1 industry membership, point-in-time. One row per (stock, industry, spell):
/// the stock belonged to `l1Name` from `inDate` up to (but excluding) `outDate` (null = still a member).
/// Used for industry-neutralization in factor analysis — pick the spell covering the rebalance date.
/// A stock can have several spells (it moved industries) so the membership is keyed by inDate too.
model SwIndustryMember {
  tsCode  String
  l1Code  String // SW level-1 industry index code, e.g. 801120.SI
  l1Name  String // SW level-1 industry name, e.g. 食品饮料
  inDate  String // date the stock entered this industry (YYYYMMDD)
  outDate String? // date it left (YYYYMMDD); null = current member

  @@id([tsCode, l1Code, inDate])
  @@index([tsCode])
}

/// Trading calendar
model TradeCal {
  exchange     String
  calDate      String
  isOpen       Int
  pretradeDate String?

  @@id([exchange, calDate])
}

/// Daily bars (unadjusted). Backtests derive backward-adjusted (hfq) prices via close × adjFactor.
model Daily {
  tsCode    String
  tradeDate String
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  preClose  Float?
  pctChg    Float?
  vol       Float?
  amount    Float?

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
}

/// Adjustment factor
model AdjFactor {
  tsCode    String
  tradeDate String
  adjFactor Float

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
}

/// Daily price limits (unadjusted up/down limit prices). The engine blocks buys at the up-limit open and sells at
/// the down-limit open (covers board-specific limits: Main Board ±10 / ST ±5 / ChiNext & STAR ±20 / BSE ±30).
model StkLimit {
  tsCode    String
  tradeDate String
  upLimit   Float // up-limit price (raw)
  downLimit Float // down-limit price (raw)

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
}

/// Dragon-Tiger List: stocks with abnormal activity that day + their net buy. Sparse event data
/// (only listed stocks have a row that day) — read exact-date via ctx.lhbNet, never carried forward.
model TopList {
  tsCode    String
  tradeDate String
  netAmount Float // Dragon-Tiger List net buy amount (yuan), summed across that day's listings

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
}

/// Daily per-stock moneyflow (Tushare moneyflow). Raw fetched point-in-time data — read exact-date via
/// ctx.moneyflow, never carried forward. Net amounts in 10k yuan (+ net inflow / − net outflow).
model Moneyflow {
  tsCode    String
  tradeDate String
  netMain   Float // main-force net amount = (large + extra-large orders) buy − sell, 10k yuan
  netTotal  Float? // net amount across all order sizes (net_mf_amount), 10k yuan — source may omit it

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
}

/// Daily valuation metrics (point-in-time by construction). Unlocks value/dividend/size factors.
model DailyBasic {
  tsCode       String
  tradeDate    String
  pe           Float?
  peTtm        Float?
  pb           Float?
  ps           Float?
  psTtm        Float?
  dvRatio      Float? // dividend yield %
  dvTtm        Float?
  totalMv      Float? // total market cap (10k yuan)
  circMv       Float? // circulating market cap (10k yuan)
  turnoverRate Float?

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
}

/// Financial indicators per report period (point-in-time via annDate). Unlocks ROE/quality factors.
/// ROE is cumulative within a year; annual reports end in 1231. The same period can appear multiple
/// times (restatements) — sync keeps the latest annDate per (tsCode, endDate).
model FinaIndicator {
  tsCode            String
  endDate           String // report period end, e.g. 20231231
  annDate           String? // announcement date — the PIT gate (value is only public on/after this)
  roe               Float? // return on equity %
  roeWaa            Float? // weighted-average return on equity %
  roa               Float? // return on assets %
  grossprofitMargin Float? // gross profit margin %
  netprofitMargin   Float? // net profit margin %
  debtToAssets      Float? // debt-to-assets ratio %
  orYoy             Float? // operating revenue YoY growth %
  netprofitYoy      Float? // net profit attributable to parent, YoY growth %
  ocfToProfit       Float? // operating cash flow / operating profit (accrual quality)

  @@id([tsCode, endDate])
  @@index([annDate])
}

/// Dividend distributions (raw; a period yields several rows across proposal→execution stages).
/// Only divProc '实施' (the "implemented" stage) is an actually-paid dividend; exDate is the PIT gate for when it took effect.
model Dividend {
  id         String  @id // ULID — no natural unique key (multiple rows per period)
  tsCode     String
  endDate    String // distribution's report period
  annDate    String? // announcement date
  exDate     String? // ex-dividend date (PIT gate)
  divProc    String? // distribution stage (raw Chinese values from source): '预案' | '股东大会通过' | '实施' | ...
  cashDiv    Float? // pre-tax cash dividend per share
  cashDivTax Float? // per-share figure incl. proposal stage

  @@index([tsCode])
}

/// Index constituents over time (monthly snapshots from index_weight). Used for point-in-time
/// universe membership (e.g. breadth over CSI 1000 = 000852.SH as-of each date).
model IndexWeight {
  indexCode String
  conCode   String
  tradeDate String // snapshot date (month-end)
  weight    Float?

  @@id([indexCode, conCode, tradeDate])
  @@index([indexCode, tradeDate])
}

/// Index daily close (e.g. CSI 300 = 000300.SH) — benchmark return curve + future regime filter.
model IndexDaily {
  tsCode    String
  tradeDate String
  close     Float

  @@id([tsCode, tradeDate])
}

// ============================================================================
// User system (invite-only beta). Passwordless: log in with email + 6-digit verification code;
// registering a new email requires a one-time invite code.
// Sessions use an opaque DB session id stored in the sid cookie (not JWT); logout deletes the row
// for instant invalidation. Design borrowed from marginalia / fangtu apps/api. IDs are
// application-generated ULIDs.
// ============================================================================

/// User
model User {
  id        String   @id // ULID
  email     String   @unique // unique identity; normalized with trim+lowercase before read/write
  name      String?
  status    String   @default("active") // 'active' | 'disabled' (disabling does not delete the account)
  createdAt DateTime @default(now())

  sessions            Session[]
  strategies          Strategy[]
  savedScreens        SavedScreen[]
  screenConversations ScreenConversation[]
}

/// Login session. id = session token (stored in sid cookie). 30-day TTL; expiry enforced by filtering on expiresAt at query time.
model Session {
  id        String   @id // ULID, i.e. the token in the cookie
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt]) // reserved for a future cleanup job
}

/// Invite code (one-time). 12-char Crockford Base32, batch-generated by the gen-invite script.
model InviteCode {
  code        String    @id // the invite code itself is the primary key
  status      String    @default("unused") // 'unused' | 'used' | 'revoked'
  usedByEmail String? // email that consumed it
  usedAt      DateTime?
  note        String? // admin note
  createdAt   DateTime  @default(now())

  @@index([status])
}

// ============================================================================
// Factor-value pre-compute table (modeled on fangtu's derived wide tables). Each row = factor ×
// stock × rebalance date. Factor values are computed and stored across the whole market (no
// pre-filter); universe filtering is done point-in-time during the backtest.
// ============================================================================
/// Persisted single-factor analysis report — the small JSON artifact per (factor, freq, start, end).
/// Regenerated on demand (?refresh=1); served instantly otherwise. Factor *values* are never stored,
/// only this report: they're computed on the fly from raw tables when the report is (re)generated.
model FactorReport {
  id         String   @id // `${userId}|${factor}|${freq}|${start}|${end}` (+ `|${neutral}` when not 'none')
  userId     String
  factor     String
  freq       String // 'month' | 'week'
  neutral    String   @default("none") // 'none' | 'size' | 'size_industry' — cross-sectional neutralization
  start      String // YYYYMMDD
  end        String // YYYYMMDD
  payload    String // JSON.stringify(FactorReport wire shape)
  computedAt DateTime

  @@index([userId, factor]) // list a user's cached runs of a factor (the "already run" chips)
}

/// A background computation (backtest / factor analysis). Status lives here (durable, cross-client
/// resume via a query); progress logs stream in-memory while live and are flushed to `logs` once on
/// finish (so a reopened finished job still shows them). A key ties the job
/// to what it computes (factor: `${factor}|${freq}|${start}|${end}`, backtest: the strategyId) so the
/// frontend can find "my running job for X" after a refresh. On boot, running jobs → stale (the worker
/// died with the process). Result is NOT stored here — it lands on the entity (FactorReport / Strategy).
model Job {
  id        String   @id // ULID
  userId    String
  kind      String // 'backtest' | 'factor'
  key       String // dedupe/lookup key (see model doc)
  status    String // 'running' | 'done' | 'error' | 'stale'
  error     String?
  logs      String? // JSON(LogLine[]) — flushed once on finish; live logs stream from memory (see lib/jobs.ts)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, kind, key, status]) // find a user's running job for a key
}

/// Email verification challenge. Only the SHA256 of the code is stored, 10-min TTL, rejected at attempts≥5 (anti-brute-force).
model EmailLoginChallenge {
  id         String    @id // ULID = challengeId
  email      String
  inviteCode String? // only set on the registration path
  codeHash   String // SHA256(6-digit verification code)
  expiresAt  DateTime
  consumedAt DateTime? // marked after successful verification, to prevent replay
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email, expiresAt])
}

// ============================================================================
// Saved user work (per-product-line persistence). Two sibling tables, one per product line — kept
// separate (not a unified table) so each column is typed to its payload. Both are owner-scoped and
// unique by (userId, name): saving upserts the row of that name, so re-running / re-saving under the
// same name updates in place instead of spawning duplicates; renaming is a new saved item. IDs are
// application-generated ULIDs.
// ============================================================================

/// A saved backtest strategy (holds a BacktestConfig as JSON). Auto-saved when a backtest runs:
/// the workbench upserts by name, so "My Strategies" lists each named strategy you've run.
model Strategy {
  id         String   @id // ULID
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  config     Json // BacktestConfig
  lastResult Json? // last BacktestSummary (metrics + nav + tradeLog) — shown on reopen, refreshed each run
  messages   Json? // ChatMessage[] — the Agent-panel conversation that authored this strategy (per-strategy)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, name]) // name = identity within a user → enables upsert-by-name
  @@index([userId, updatedAt]) // list a user's strategies, newest first
}

/// A factor as code (code-first, mirrors Strategy). `code` is a defineFactor TS module, compiled +
/// run cross-sectionally in the factor analysis. Two kinds of rows share this table:
///   - user factors: id = ULID, userId = the owner;
///   - built-in presets: id = stable slug (ep/mom/…), userId = 'builtin' sentinel — seeded from
///     factor/builtin-factors.ts (git is the source of truth), read-only via the routes.
/// Plain userId (no relation), like FactorReport.
model Factor {
  id        String   @id // ULID, or a preset slug for builtin rows
  userId    String
  name      String
  code      String // defineFactor TS source
  messages  Json? // ChatMessage[] — the Agent-panel conversation that authored this factor (per-factor)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name]) // name = identity within a user → upsert-by-name
  @@index([userId, updatedAt]) // list a user's factors, newest first
}

/// An agent conversation on the screen page (a "session card" on the card wall). Strategy/factor
/// conversations ride their host entity (Strategy.messages / Factor.messages); a screening
/// conversation has no host, so it gets its own row. Query cards (SavedScreen) are deliberately NOT
/// linked to conversations — deleting a conversation never touches saved cards.
model ScreenConversation {
  id        String   @id // ULID
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String // defaults to the first user message, truncated; renamable
  messages  Json // ChatMessage[] (parts shape)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

/// A saved screen query (holds a ScreenSpec as JSON). Saved on demand — the user clicks "Save" to keep
/// an exploratory query; also upsert by name.
model SavedScreen {
  id        String   @id // ULID
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  spec      Json // ScreenSpec
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId, updatedAt])
}
