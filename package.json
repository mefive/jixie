{
  "name": "jixie",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "pnpm --filter api smoke",
    "sync": "pnpm --filter api sync",
    "peek": "pnpm --filter api peek"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma"]
  }
}
